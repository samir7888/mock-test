# ==============================================================================
#                      PREPED ENVIRONMENT CONFIGURATION
# ==============================================================================

# 1. DATABASE CONFIGURATION (PostgreSQL)
# Prisma 7 reads configuration from prisma.config.ts and connects to this URL at runtime.
# Local development using Prisma Dev engine:
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."
# Production standard PostgreSQL database connection:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/preped_db?schema=public"

# 2. CLERK AUTHENTICATION (Sign up on Clerk.com to get your keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk sign-in and sign-up custom page routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ==============================================================================
# NOTE: Copy this file as '.env' and fill in your actual credentials.
# ==============================================================================
